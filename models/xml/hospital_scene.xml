<mujoco model="hospital_scene">
    <compiler angle="degree"/>
    <option timestep="0.0005"/>

    <asset>
        <material name="floor_mat" rgba="0.85 0.85 0.80 1"/>
        <material name="wall_mat" rgba="0.7 0.7 0.65 1"/>
        <material name="bed_mat" rgba="0.3 0.5 0.7 1"/>
        <material name="charging_mat" rgba="0.2 0.8 0.3 1"/>
        <material name="supply_mat" rgba="0.9 0.2 0.2 1"/>
        <material name="waypoint_mat" rgba="1.0 0.6 0.0 0.5"/>
    </asset>

    <worldbody>
        <light name="sun" directional="true" dir="-1 -1 -2" castshadow="true"/>
        <light name="room_light" pos="0 0 4" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>

        <!-- Hospital Floor (12m x 10m) -->
        <geom name="ground" type="plane" size="8 6 0.1" material="floor_mat"/>

        <!-- ============ WALLS (with collision) ============ -->
        <!-- North wall -->
        <geom name="wall_north" type="box" pos="-3 5.5 1" size="8 0.1 1" material="wall_mat"/>
        <!-- South wall -->
        <geom name="wall_south" type="box" pos="-3 -5.5 1" size="8 0.1 1" material="wall_mat"/>
        <!-- East wall -->
        <geom name="wall_east" type="box" pos="4.5 0 1" size="0.1 5.5 1" material="wall_mat"/>
        <!-- West wall -->
        <geom name="wall_west" type="box" pos="-7 0 1" size="0.1 5.5 1" material="wall_mat"/>

        <!-- ============ MEDICINE SUPPLY ZONE (Red) ============ -->
        <body name="supply_zone" pos="2 0 0">
            <!-- Red platform for medicine supply -->
            <geom name="supply_base" type="box" pos="0 0 0.02" size="0.6 0.6 0.02" 
                  material="supply_mat" contype="0" conaffinity="0"/>
            <!-- Red marker post -->
            <geom name="supply_marker" type="cylinder" pos="0.5 0.5 0.4" size="0.06 0.4" 
                  rgba="1.0 0.0 0.0 1" contype="0" conaffinity="0"/>
            <!-- Cross symbol on top -->
            <geom name="supply_cross_h" type="box" pos="0 0 0.06" size="0.3 0.08 0.01" 
                  rgba="1.0 1.0 1.0 1" contype="0" conaffinity="0"/>
            <geom name="supply_cross_v" type="box" pos="0 0 0.06" size="0.08 0.3 0.01" 
                  rgba="1.0 1.0 1.0 1" contype="0" conaffinity="0"/>
        </body>

        <!-- ============ CHARGING STATION (Southeast Corner) ============ -->
        <body name="charging_station" pos="3.5 -4.5 0">
            <!-- Base platform -->
            <geom name="charging_base" type="box" pos="0 0 0.02" size="0.5 0.5 0.02" 
                  material="charging_mat" contype="0" conaffinity="0"/>
            <!-- Marker post -->
            <geom name="charging_marker" type="cylinder" pos="0 0 0.4" size="0.08 0.4" 
                  rgba="0.0 1.0 0.0 1" contype="0" conaffinity="0"/>
            <!-- "C" indicator for Charging -->
            <geom name="charging_indicator" type="box" pos="0 0 0.85" size="0.15 0.03 0.15" 
                  rgba="0.0 0.8 0.0 1" contype="0" conaffinity="0"/>
        </body>

        <!-- ============ PATIENT BEDS (SOLID with collision) ============ -->
        <!-- Bed 1: waypoint at -3, -1 (robot approaches from +Y side) -->
        <body name="bed_1" pos="-3 -2.5 0">
            <!-- Solid bed block for collision -->
            <geom name="bed_1_solid" type="box" pos="0 0 0.35" size="1.0 0.6 0.35" material="bed_mat"/>
            <!-- Headboard -->
            <geom name="bed_1_headboard" type="box" pos="-0.9 0 0.55" size="0.1 0.5 0.2" rgba="0.2 0.4 0.6 1"/>
            <geom name="waypoint_1" type="cylinder" pos="0 1.2 0.01" size="0.25 0.01" 
                  material="waypoint_mat" contype="0" conaffinity="0"/>
        </body>

        <!-- Bed 2: waypoint at -5, -1 (robot approaches from +Y side) -->
        <body name="bed_2" pos="-5 -2.5 0">
            <geom name="bed_2_solid" type="box" pos="0 0 0.35" size="1.0 0.6 0.35" material="bed_mat"/>
            <geom name="bed_2_headboard" type="box" pos="-0.9 0 0.55" size="0.1 0.5 0.2" rgba="0.2 0.4 0.6 1"/>
            <geom name="waypoint_2" type="cylinder" pos="0 1.2 0.01" size="0.25 0.01" 
                  material="waypoint_mat" contype="0" conaffinity="0"/>
        </body>

        <!-- Bed 3: waypoint at -5, 1 (robot approaches from -Y side) -->
        <body name="bed_3" pos="-5 2.5 0">
            <geom name="bed_3_solid" type="box" pos="0 0 0.35" size="1.0 0.6 0.35" material="bed_mat"/>
            <geom name="bed_3_headboard" type="box" pos="-0.9 0 0.55" size="0.1 0.5 0.2" rgba="0.2 0.4 0.6 1"/>
            <geom name="waypoint_3" type="cylinder" pos="0 -1.2 0.01" size="0.25 0.01" 
                  material="waypoint_mat" contype="0" conaffinity="0"/>
        </body>

        <!-- ============ BIPEDAL ROBOT at Charging Station ============ -->
        <!-- Robot starts at origin, facing +X direction -->
        <body name="torso" pos="0 0 1.6">
            <geom type="capsule" size="0.1 0.3" mass="8" rgba="0.8 0.2 0.2 1"/>
            <joint type="free"/>

            <!-- Right leg -->
            <body name="right_hip_z" pos="0 -0.05 -0.25">
                <joint name="right_hip_z_j" type="hinge" axis="0 0 1" range="-20 20"/>
                <geom type="capsule" size="0.07 0.025" mass="0.1" rgba="0.2 0.2 0.8 1" 
                      pos="0 0.0 -0.025" contype="0" conaffinity="0"/>
                <body name="right_hip_y" pos="0 -0.00 -0.05">
                    <joint name="right_hip_y_j" type="hinge" axis="1 0 0" range="-20 20"/>
                    <geom type="capsule" size="0.07 0.025" mass="0.1" rgba="0.2 0.2 0.8 1" 
                          pos="0 -0.025 0.0" euler="90 0 0" contype="0" conaffinity="0"/>
                    <body name="right_thigh" pos="0 -0.05 -0.0">
                        <joint name="right_hip" type="hinge" axis="0 1 0" range="-60 60"/>
                        <geom type="capsule" size="0.07 0.3" mass="1" rgba="0.2 0.2 0.8 1" 
                              pos="0 0 -0.3" contype="0" conaffinity="0"/>
                        <body name="right_shin" pos="0 0 -0.6">
                            <joint name="right_knee" type="hinge" axis="0 1 0" range="-120 -5"/>
                            <geom name="right_shin_geom" type="capsule" size="0.06 0.3" mass="1" 
                                  rgba="0.2 0.2 0.8 1" pos="0 0 -0.3"/>
                            <body name="right_foot" pos="0 0 -0.6">
                                <joint name="right_foot_j" type="hinge" axis="0 1 0" range="-60 60"/>
                                <geom name="right_foot_geom" type="capsule" size="0.06 0.08" mass="0.1" 
                                      rgba="0.2 0.2 0.8 1" euler="-0 90 0"/>
                            </body>
                        </body>
                    </body>
                </body>
            </body>

            <!-- Left leg -->
            <body name="left_hip_z" pos="0 0.05 -0.25">
                <joint name="left_hip_z_j" type="hinge" axis="0 0 1" range="-20 20"/>
                <geom type="capsule" size="0.07 0.025" mass="0.1" rgba="0.2 0.8 0.2 1" 
                      pos="0 0.0 -0.025" contype="0" conaffinity="0"/>
                <body name="left_hip_y" pos="0 0.0 -0.05">
                    <joint name="left_hip_y_j" type="hinge" axis="1 0 0" range="-20 20"/>
                    <geom type="capsule" size="0.07 0.025" mass="0.1" rgba="0.2 0.8 0.2 1" 
                          pos="0 0.025 0.0" euler="90 0 0" contype="0" conaffinity="0"/>
                    <body name="left_thigh" pos="0 0.05 -0.0">
                        <joint name="left_hip" type="hinge" axis="0 1 0" range="-120 120"/>
                        <geom type="capsule" size="0.07 0.3" mass="1" rgba="0.2 0.8 0.2 1" 
                              pos="0 0 -0.3" contype="0" conaffinity="0"/>
                        <body name="left_shin" pos="0 0 -0.6">
                            <joint name="left_knee" type="hinge" axis="0 1 0" range="-120 -5"/>
                            <geom name="left_shin_geom" type="capsule" size="0.06 0.3" mass="1" 
                                  rgba="0.2 0.8 0.2 1" pos="0 0 -0.3"/>
                            <body name="left_foot" pos="0 0 -0.6">
                                <joint name="left_foot_j" type="hinge" axis="0 1 0" range="-60 60"/>
                                <geom name="left_foot_geom" type="capsule" size="0.06 0.08" mass="0.1" 
                                      rgba="0.2 0.2 0.8 1" euler="-0 90 0"/>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <velocity joint="right_hip_z_j" kv="15"/>
        <velocity joint="right_hip_y_j" kv="30"/>
        <velocity joint="right_hip" kv="30"/>
        <velocity joint="right_knee" kv="30"/>
        <velocity joint="right_foot_j" kv="0.1"/>
        <velocity joint="left_hip_z_j" kv="15"/>
        <velocity joint="left_hip_y_j" kv="30"/>
        <velocity joint="left_hip" kv="30"/>
        <velocity joint="left_knee" kv="30"/>
        <velocity joint="left_foot_j" kv="0.1"/>
    </actuator>
</mujoco>
